{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A server-side mod that guarantees max-level enchantments on villager trade outputs, with separate gamerules for books and items.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/MaxVillagerTrades",
		"sources": "https://github.com/brainage04/MaxVillagerTrades"
	},
	"license": "MIT",
	"icon": "assets/maxvillagertrades/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.brainage04.maxvillagertrades.MaxVillagerTrades"
		]
	},
	"mixins": [
		"maxvillagertrades.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"accessWidener": "maxvillagertrades.accesswidener"
}
